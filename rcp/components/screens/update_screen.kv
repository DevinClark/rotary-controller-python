#: import StringItem rcp.components.widgets.string_item
#: import NumberItem rcp.components.widgets.number_item
#: import BooleanItem rcp.components.widgets.boolean_item

<UpdateScreen>:
  formats: app.formats
  BoxLayout:
    title: "Software Update"
    orientation: "vertical"
    padding: 10
    spacing: 5
    ScreenHeader:
      text: "Software Update"
      size_hint_y: None
      height: 60

    Button:
      height: 60
      size_hint_x: None
      width: 250
      text: "Update"
      on_release: root.update()
      size_hint_y: None
    TitleItem:
      name: "Update Status"
      size_hint_y: None
      height: 36
    TextInput:
      readonly: True
      multiline: True
      text: root.status

